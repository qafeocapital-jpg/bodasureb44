{
  "name": "Group",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "sacco",
        "chama",
        "welfare",
        "self_help",
        "other"
      ],
      "default": "sacco"
    },
    "county_id": {
      "type": "string"
    },
    "sasapay_account_number": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "pending"
      ],
      "default": "active"
    },
    "member_count": {
      "type": "integer",
      "default": 0
    },
    "description": {
      "type": "string"
    },
    "bank_name": {
      "type": "string"
    },
    "bank_account_name": {
      "type": "string"
    },
    "bank_account_number": {
      "type": "string"
    },
    "bank_branch": {
      "type": "string"
    },
    "mpesa_till_number": {
      "type": "string"
    },
    "official_name": {
      "type": "string"
    },
    "official_phone": {
      "type": "string"
    },
    "official_email": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "type",
    "county_id"
  ]
}